APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
PRACTICE_RECORDINGS_DISK=local
PRACTICE_RECORDINGS_MAX_AUDIO_KB=51200
QUEUE_CONNECTION=database

AI_WORKER_PYTHON=
AI_WORKER_ENTRYPOINT=
AI_WORKER_TIMEOUT=300
AI_WORKER_IDLE_TIMEOUT=60
AI_TRANSCRIPTION_PROVIDER=python_worker
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_TIMEOUT=120
OPENAI_TRANSCRIPTION_MAX_BYTES=26214400
OPENAI_TRANSCRIPTION_LANGUAGE=
OPENAI_TRANSCRIPTION_PROMPT=
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-flash
GEMINI_TRANSCRIPTION_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
GEMINI_TRANSCRIPTION_TIMEOUT=120
GEMINI_TRANSCRIPTION_MAX_BYTES=15728640
GEMINI_TRANSCRIPTION_MIME_TYPE=
GEMINI_TRANSCRIPTION_PROMPT=Transcribe this audio exactly. Return only the transcript text.
XAI_TRANSCRIPTION_ENDPOINT=https://api.x.ai/v1/stt
XAI_TRANSCRIPTION_TIMEOUT=120
XAI_TRANSCRIPTION_MAX_BYTES=524288000
XAI_TRANSCRIPTION_LANGUAGE=en
XAI_TRANSCRIPTION_FORMAT=true
XAI_TRANSCRIPTION_DIARIZE=false
XAI_TRANSCRIPTION_FILLER_WORDS=false
XAI_TRANSCRIPTION_KEYTERMS=
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TRANSCRIPTION_ENDPOINT=https://api.groq.com/openai/v1/audio/transcriptions
GROQ_TRANSCRIPTION_TIMEOUT=120
GROQ_TRANSCRIPTION_MAX_BYTES=26214400
GROQ_TRANSCRIPTION_LANGUAGE=en
GROQ_TRANSCRIPTION_PROMPT=
GROQ_TRANSCRIPTION_MIME_TYPE=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=

AI_FEEDBACK_PROVIDER=local
AI_FEEDBACK_API_KEY=
AI_FEEDBACK_TIMEOUT=60
OPENAI_FEEDBACK_MODEL=gpt-4o-mini
OPENAI_FEEDBACK_ENDPOINT=https://api.openai.com/v1/chat/completions
GEMINI_FEEDBACK_MODEL=gemini-2.5-flash
GEMINI_FEEDBACK_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
GEMINI_FEEDBACK_TEMPERATURE=0.3
GROK_FEEDBACK_MODEL=grok-4.3
GROK_FEEDBACK_ENDPOINT=https://api.x.ai/v1/chat/completions
GROK_FEEDBACK_TEMPERATURE=0.3
GROQ_FEEDBACK_MODEL=llama-3.3-70b-versatile
GROQ_FEEDBACK_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
GROQ_FEEDBACK_TEMPERATURE=0.3
SPEAKING_FEEDBACK_PROVIDER=local
SPEAKING_FEEDBACK_ENDPOINT=
SPEAKING_FEEDBACK_API_KEY=
SPEAKING_FEEDBACK_TIMEOUT=60

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_THROW=true
AWS_REPORT=true

VITE_APP_NAME="${APP_NAME}"
